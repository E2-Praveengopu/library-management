# ───────────────────────────────────────────
# DEPENDENCIES
# Installed by "npm install" — never commit these.
# Anyone cloning the repo runs "npm install" to get them back.
# ───────────────────────────────────────────
node_modules/

# ───────────────────────────────────────────
# WEBPACK BUILD OUTPUT
# Generated by "npm run build" — not source code.
# The dist/ folder is rebuilt from source files each time.
# ───────────────────────────────────────────
dist/

# ───────────────────────────────────────────
# ENVIRONMENT VARIABLES
# May contain API base URLs or secrets.
# ───────────────────────────────────────────
.env
.env.local
.env.production

# ───────────────────────────────────────────
# NPM LOG FILES
# Created automatically when npm commands fail.
# ───────────────────────────────────────────
npm-debug.log
npm-debug.log*
*.log

# ───────────────────────────────────────────
# OPERATING SYSTEM FILES
# Auto-created by Windows and macOS — not part of the project.
# ───────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
